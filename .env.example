# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
# Obtén estos valores desde tu panel de Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-publica"

# Clave service-role de Supabase (SOLO servidor, NUNCA NEXT_PUBLIC). La usa el
# bot de Telegram (cliente admin) para leer el ERP saltando RLS de forma segura.
# Project Settings -> API -> service_role secret.
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# ----------------------------------------------------------------------------
# Bots de IA (DeepSeek, vía endpoint compatible con OpenAI: /chat/completions).
# IMPORTANTE: el bot WEB (Asistente IA) y el bot de TELEGRAM usan variables
# DISTINTAS (no se comparten). Si faltan, el bot respectivo deja de responder.
# Estas variables viven SOLO en el entorno de despliegue (p. ej. Vercel).
# ----------------------------------------------------------------------------

# Bot interno web (/asistente-ia). Sin estas tres, el endpoint responde
# "DeepSeek no está configurado en el servidor".
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Bot de Telegram (cajero). Mensajería:
TELEGRAM_BOT_TOKEN="123456:ABC..."           # token del bot (@BotFather)
TELEGRAM_WEBHOOK_SECRET="un-secreto-largo"    # secret_token del webhook
# Allowlist (autorización REAL del bot). Sin esto el bot NO responde a comandos
# de datos (envía /id al bot para obtener tus identificadores):
TELEGRAM_ALLOWED_CHAT_ID="-1001234567890"     # chat/grupo permitido (grupos = negativo)
TELEGRAM_ALLOWED_USER_IDS="11111111,22222222" # user ids permitidos (CSV)
# IA del bot de Telegram (separadas de las del bot web):
DEEPSEEK_TELEGRAM_API_KEY="sk-..."
DEEPSEEK_TELEGRAM_BASE_URL="https://api.deepseek.com"
DEEPSEEK_TELEGRAM_MODEL="deepseek-chat"
# Mantener SIN definir (o != true) para conservar el bot en SOLO LECTURA:
# TELEGRAM_CAJERO_ENABLE_WRITE_ACTIONS="false"
